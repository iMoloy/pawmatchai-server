# ==============================================
# PawMatchAI Backend (pawmatch-server) — Environment Variables
# ==============================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control!

# ----- Server -----
PORT=5000

# ----- MongoDB -----
# Local development:
MONGO_URI=mongodb://localhost:27017/pawmatchai
# MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/pawmatchai?retryWrites=true&w=majority

# ----- Authentication -----
# Generate a strong random secret (e.g. run: openssl rand -base64 64)
JWT_SECRET=replace_with_a_very_long_random_secret_key_here

# ----- Google OAuth (for social login) -----
# Create credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ----- LLM Provider (for real AI features) -----
# Uncomment the provider you want to use:

# Google Gemini:
# GEMINI_API_KEY=your-gemini-api-key

# OpenAI:
# OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude:
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ----- CORS -----
# The frontend URL (comma-separated for multiple)
CLIENT_URL=http://localhost:3000
